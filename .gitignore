# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.conda/

# Editors
.idea/
.vscode/

# Sensitive data
mcp_servers/mail_server/mail_config.json
**/.env
**/api_keys.py

# Runtime data
data/
!data/.gitkeep

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Cursor
.cursorrules
.cursor/

# OLV-specific (mirrors Open-LLM-VTuber/.gitignore for safety)
Open-LLM-VTuber/conf.yaml
Open-LLM-VTuber/mcp_servers.json
Open-LLM-VTuber/cache/
Open-LLM-VTuber/chat_history/
Open-LLM-VTuber/logs/
Open-LLM-VTuber/models/
Open-LLM-VTuber/.venv/
Open-LLM-VTuber/conf.yaml.backup

# Frontend build artifacts
frontend_overlay/upstream/node_modules/
frontend_overlay/upstream/dist/
frontend_overlay/upstream/out/
frontend_overlay/upstream/release/

# OLV compiled frontend bundle (auto-generated, changes on every build)
# Only index.html is version-controlled to track which bundle is active
Open-LLM-VTuber/frontend/assets/main-*.js
Open-LLM-VTuber/frontend/assets/main-*.css

# Stray binary assets at repo root (should not be committed here)
*.webp

# SoVITS 合成测试临时产物(任何位置的 test*.wav 都排除)
**/test*.wav
