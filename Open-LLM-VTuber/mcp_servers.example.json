{
  "mcp_servers": {
    "time": {
      "command": "uvx",
      "args": ["mcp-server-time", "--local-timezone=Asia/Shanghai"]
    },
    "ddg-search": {
      "command": "uvx",
      "args": ["duckduckgo-mcp-server"]
    },
    "todo": {
      "command": "python",
      "args": ["-m", "mcp_servers.todo_server.server"],
      "cwd": "..",
      "env": {
        "TODO_DB_PATH": "../data/todos.db"
      }
    },
    "mail": {
      "command": "python",
      "args": ["-m", "mcp_servers.mail_server.server"],
      "cwd": "..",
      "env": {
        "MAIL_CONFIG_PATH": "../mcp_servers/mail_server/mail_config.json"
      }
    }
  }
}
